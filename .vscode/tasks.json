{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build LaTeX report",
            "type": "shell",
            "command": "latexmk",
            "args": [
                "-pdf",
                "-interaction=nonstopmode",
                "-file-line-error",
                "report.tex"
            ],
            "options": {
                "cwd": "${workspaceFolder}/report"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "never",
                "panel": "dedicated",
                "clear": true
            }
        }
    ]
}
